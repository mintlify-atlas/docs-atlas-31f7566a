  "keyFeatures": [
    "Convert FVD (No Limits 2) CSV exports to UC3 world files with adjustable heartlining",
    "Migrate Ultimate Coaster 2 save files (.uc2sav) to UC3 world format including terrain, coasters, and scenery",
    "Generate flat or heightmap-based terrain files at configurable resolutions (64–512 vertices per direction)",
    "Supports 30+ coaster type mappings from UC2 to UC3",
    "Custom VProto library for reading and writing UC3's protobuf-based binary file format"
  ],
  "publicApiSurface": [
